# mex-call uses Claude Code's own auth for the brain (no API key needed there).

# --- Recall (MVP 1: meeting transport) ---------------------------------------
# Private, server-side only — never embed in distributed/client code.
RECALL_API_KEY=

# Region-specific Recall base URL. Find your region in the Recall dashboard.
# Default if unset: https://us-west-2.recall.ai
# RECALL_API_URL=https://us-west-2.recall.ai

# Public URL Recall should POST realtime webhooks to. In dev, leave this unset
# and run `ngrok http 8080` — mex-call auto-detects the ngrok tunnel. In prod,
# set this to your deployed domain (no trailing slash).
# MEXCALL_PUBLIC_URL=https://your-domain.example
